{
  "description": "Memory lifecycle hooks — auto-save before compact, log commits, show handoff on start",
  "hooks": {
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/session-save.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'node ${CLAUDE_PLUGIN_ROOT}/scripts/memory.js note \"COMMIT: $(git log --oneline -1 2>/dev/null)\"'"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'MEM_DIR=$(node ${CLAUDE_PLUGIN_ROOT}/scripts/memory.js dir 2>/dev/null); cat \"$MEM_DIR/workstreams/handoff.md\" 2>/dev/null'"
          }
        ]
      }
    ]
  }
}